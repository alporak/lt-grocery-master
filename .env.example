# Krepza deployment — copy to .env and fill in values
# Minimum required: NEXTAUTH_URL, AUTH_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# For ads: also set NEXT_PUBLIC_ADSENSE_ID

# Database
DATABASE_URL="file:../../data/grocery.db"

# Embedder service
EMBEDDER_URL=http://embedder:8000

# Gemini API — get free keys at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI2_API_KEY=
GEMINI3_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-04-17
GEMINI_RPM=10                  # requests per minute per key (free tier default: 10)
GEMINI_BATCH_SIZE=200          # products per request
GEMINI_THINKING_BUDGET=0       # thinking tokens (0 = disabled, fastest)

# Scraper defaults
SCRAPE_INTERVAL_HOURS=24
SCRAPE_HEADLESS=true

# Cloudflare Tunnel — create tunnel at https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Select "Docker" environment when creating tunnel to get the token
# WARNING: Never commit the real token to git. .env is gitignored — keep it there.
TUNNEL_TOKEN=

# Authentication — Google/Facebook OAuth
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=
# Public URL of this instance — the ONLY variable to change per deployment
# Sets the domain for OAuth redirects, session cookies, and all URL references
# Production: NEXTAUTH_URL=https://krepza.lt
# Development: NEXTAUTH_URL=http://localhost:3131
NEXTAUTH_URL=https://krepza.lt
PUBLIC_URL=${NEXTAUTH_URL}
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
#   Add {NEXTAUTH_URL}/api/auth/callback/google as authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook OAuth — create at https://developers.facebook.com
#   Add {NEXTAUTH_URL}/api/auth/callback/facebook as authorized redirect URI
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google AdSense — publisher ID
# REQUIRED for production (ADSN-04). Format: pub-XXXXXXXXXXXXXXXX
# Find yours at: https://adsense.google.com → Account → Settings → Account information
# Leave empty to disable all ads across the app (development only)
# Production deploy checklist: uncomment and set this value BEFORE deploying Phase 9+
NEXT_PUBLIC_ADSENSE_ID=
