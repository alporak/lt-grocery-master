generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  name          String
  chain         String
  url           String
  enabled       Boolean   @default(true)
  lastScrapedAt DateTime?

  products   Product[]
  locations  StoreLocation[]
  scrapeLogs ScrapeLog[]
}

model StoreLocation {
  id           Int     @id @default(autoincrement())
  storeId      Int
  address      String
  city         String
  lat          Float?
  lng          Float?
  sizeCategory String  @default("MEDIUM")
  openingHours String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([city])
}

model Product {
  id          Int      @id @default(autoincrement())
  storeId     Int
  externalId  String
  nameLt      String
  nameEn      String?
  categoryLt  String?
  categoryEn  String?
  brand       String?
  weightValue Float?
  weightUnit  String?
  imageUrl    String?
  productUrl  String?
  barcode      String?
  searchIndex  String?
  canonicalCategory String?
  subcategory  String?
  enrichment   String?
  enrichedAt   DateTime?
  enrichmentVersion Int?
  reviewedAt   DateTime?
  productGroupId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  priceRecords PriceRecord[]
  productGroup ProductGroup? @relation(fields: [productGroupId], references: [id])

  @@unique([storeId, externalId])
  @@index([nameLt])
  @@index([categoryLt])
  @@index([storeId])
  @@index([searchIndex])
  @@index([canonicalCategory])
  @@index([subcategory])
  @@index([productGroupId])
  @@index([brand])
  @@index([reviewedAt])
}

model ProductGroup {
  id                Int      @id @default(autoincrement())
  name              String
  nameEn            String?
  canonicalCategory String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products Product[]

  @@index([canonicalCategory])
}

model PriceRecord {
  id           Int      @id @default(autoincrement())
  productId    Int
  regularPrice Float
  salePrice    Float?
  unitPrice    Float?
  unitLabel    String?
  loyaltyPrice Float?
  campaignText String?
  scrapedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, scrapedAt])
  @@index([scrapedAt])
}

model GroceryList {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items GroceryListItem[]
}

model GroceryListItem {
  id                   Int     @id @default(autoincrement())
  listId               Int
  itemName             String
  quantity             Float   @default(1)
  unit                 String?
  checked              Boolean @default(false)
  pinnedProductGroupId Int?
  preferredBrand       String?

  list GroceryList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model Settings {
  key   String @id
  value String
}

model ScrapeLog {
  id           Int      @id @default(autoincrement())
  storeId      Int
  status       String
  productCount Int      @default(0)
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([startedAt])
}

model ScraperConfig {
  id            Int      @id @default(autoincrement())
  name          String
  url           String
  storeName     String
  chain         String   @default("CUSTOM")
  containerSel  String
  nameSel       String
  priceSel      String
  linkSel       String?
  imageSel      String?
  categorySel   String?
  paginationSel String?
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  lastRunCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
