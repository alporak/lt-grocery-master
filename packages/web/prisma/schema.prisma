generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  chain       String   // IKI, BARBORA, RIMI, PROMO
  url         String
  enabled     Boolean  @default(true)
  lastScrapedAt DateTime?

  products   Product[]
  locations  StoreLocation[]
  scrapeLogs ScrapeLog[]
}

model StoreLocation {
  id           Int     @id @default(autoincrement())
  storeId      Int
  address      String
  city         String
  lat          Float?
  lng          Float?
  sizeCategory String  @default("MEDIUM") // SMALL, MEDIUM, LARGE, HYPERMARKET
  openingHours String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([city])
}

model Product {
  id          Int      @id @default(autoincrement())
  storeId     Int
  externalId  String
  nameLt      String
  nameEn      String?
  categoryLt  String?
  categoryEn  String?
  brand       String?
  weightValue Float?
  weightUnit  String?
  imageUrl    String?
  productUrl  String?
  barcode      String?
  searchIndex  String?   // normalized lowercase no-diacritics name for search
  canonicalCategory String? // embedder-assigned normalized category ID
  subcategory  String?   // more specific type within category (e.g. "sparkling water")
  enrichment        String?   // JSON blob from LLM enrichment
  enrichedAt        DateTime? // when LLM enrichment was last run
  enrichmentVersion Int?      // version of enrichment prompt used
  enrichmentSource  String?   // "auto" (swarm/Gemini) | "manual" (copy-paste workflow)
  reviewedAt        DateTime? // set when a human manually approves this product
  productGroupId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  priceRecords PriceRecord[]
  productGroup ProductGroup? @relation(fields: [productGroupId], references: [id])

  @@unique([storeId, externalId])
  @@index([nameLt])
  @@index([categoryLt])
  @@index([storeId])
  @@index([searchIndex])
  @@index([canonicalCategory])
  @@index([subcategory])
  @@index([productGroupId])
  @@index([brand])
  @@index([reviewedAt])
}

model ProductGroup {
  id                Int      @id @default(autoincrement())
  name              String
  nameEn            String?
  canonicalCategory String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products Product[]

  @@index([canonicalCategory])
}

model PriceRecord {
  id           Int      @id @default(autoincrement())
  productId    Int
  regularPrice Float
  salePrice    Float?
  unitPrice    Float?
  unitLabel    String?
  loyaltyPrice Float?
  campaignText String?
  scrapedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, scrapedAt])
  @@index([scrapedAt])
}

model GroceryList {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items GroceryListItem[]
}

model GroceryListItem {
  id                 Int     @id @default(autoincrement())
  listId             Int
  itemName           String
  quantity           Float   @default(1)
  unit               String?
  checked            Boolean @default(false)
  pinnedProductGroupId Int?  // if set, use this product group for comparison
  pinnedProductId    Int?    // specific product chosen via Products tab
  preferredBrand     String? // brand preference for this item

  list GroceryList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model Settings {
  key   String @id
  value String // JSON-encoded value
}

model ScrapeLog {
  id           Int      @id @default(autoincrement())
  storeId      Int
  status       String   // running, success, error
  productCount Int      @default(0)
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([startedAt])
}

model ScraperConfig {
  id            Int      @id @default(autoincrement())
  name          String
  url           String
  storeName     String   // User-defined store label
  chain         String   @default("CUSTOM")
  containerSel  String   // CSS selector for each product container
  nameSel       String   // CSS selector for product name (relative to container)
  priceSel      String   // CSS selector for product price (relative to container)
  linkSel       String?  // CSS selector for product link
  imageSel      String?  // CSS selector for product image
  categorySel   String?  // CSS selector for product category
  paginationSel String?  // CSS selector for next page link
  enabled       Boolean  @default(true)
  lastRunAt     DateTime?
  lastRunCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
